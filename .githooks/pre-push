#!/bin/sh
# Pre-push gate: the engine self-tests and the production build must pass
# before anything reaches the remote (and triggers the Pages deploy).
#
# Activated by `npm install` (the "prepare" script runs
# `git config core.hooksPath .githooks`). To wire it manually:
#   git config core.hooksPath .githooks
set -e
cd "$(git rev-parse --show-toplevel)"

if [ ! -d node_modules ]; then
  echo "pre-push: node_modules missing - running npm install first"
  npm install --no-audit --no-fund
fi

echo "pre-push: running engine self-tests"
npm test --silent

echo "pre-push: running production build"
npm run build --silent

echo "pre-push: all checks passed - pushing"
